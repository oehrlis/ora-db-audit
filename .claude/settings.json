{
  "attribution": {
    "commit": ""
  },
  "autoApprove": {
    "read": true,
    "write": false,
    "execute": false
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "markdownlint --fix $CLAUDE_TOOL_OUTPUT_PATH 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
